# SMTP Configuration for Inquiries (Example for Gmail)
# 1. Go to your Google Account -> Security -> 2-Step Verification -> App Passwords
# 2. Generate a new App Password for "Mail" and "Other (Custom Name)"
# 3. Use that 16-character password in SMTP_PASS below

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-character-app-password
INQUIRY_DESTINATION_EMAIL=wesley723@163.com
